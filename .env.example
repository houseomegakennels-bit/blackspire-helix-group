COMMAND_ADMIN_TOKEN=replace-with-long-random-admin-token
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_BOT_TOKEN=
PUBLIC_BASE_URL=http://localhost:8787
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
CODEX_API_ENDPOINT=
CODEX_API_KEY=
GITHUB_TOKEN=
BLACKSPIRE_DB_PATH=.blackspire-command/command.sqlite
# Root path Hermes uses for git/build/test operations. In docker-compose this is set
# to /workspace/blackspire, where the host repo is bind-mounted into the worker container.
BLACKSPIRE_WORKSPACE_ROOT=.
