{
  "name": "Blackspire Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bash ${containerWorkspaceFolder}/scripts/bootstrap-codespace.sh",
  "containerEnv": {
    "BLACKSPIRE_ENVIRONMENT": "codespace",
    "BLACKSPIRE_STATE_OWNER": "codespace-disposable",
    "BLACKSPIRE_PROVIDER_MODE": "manual"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "GitHub.copilot",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "portsAttributes": {
    "8790": {
      "label": "Disposable Unified Jarvis test",
      "onAutoForward": "notify",
      "visibility": "private",
      "protocol": "https"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }
}
