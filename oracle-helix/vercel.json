{
  "version": 2,
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-scores",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-odds",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sync-injuries",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync-teams-players",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/generate-signals",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/generate-research-cards",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sync-props",
      "schedule": "15 9 * * 1"
    },
    {
      "path": "/api/cron/sync-weather",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sync-player-stats",
      "schedule": "0 11 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
