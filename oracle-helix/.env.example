# ============================================================
# ORACLE HELIX — Environment Variables
# Powered by BLACKSPIRE HELIX GROUP
# Copy this file to .env.local and fill in all values
# ============================================================

# ---- SUPABASE (create new project at supabase.com) ---------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# ---- ANTHROPIC / CLAUDE API --------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ---- UPSTASH REDIS (free tier at upstash.com) --------------
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ---- SPORTS DATA APIs (all have free tiers) ----------------
# The Odds API — theoddsapi.com — free: 500 req/mo
THE_ODDS_API_KEY=your_odds_api_key_here
THE_ODDS_API_BASE=https://api.the-odds-api.com/v4

# ESPN API (unofficial, no key needed — public endpoints)
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports

# MLB Stats API (official, free, no key needed)
MLB_API_BASE=https://statsapi.mlb.com/api/v1

# NHL Stats API (official, free, no key needed)
NHL_API_BASE=https://api-web.nhle.com/v1

# Ball Don't Lie — NBA stats (balldontlie.io, free tier)
BALLDONTLIE_API_KEY=your_balldontlie_key_here
BALLDONTLIE_API_BASE=https://api.balldontlie.io/v1

# Open-Meteo — Weather (100% free, no key needed)
WEATHER_API_BASE=https://api.open-meteo.com/v1

# ---- APP CONFIG --------------------------------------------
PORT=3001
NODE_ENV=development
ORACLE_HELIX_VERSION=1.0.0
FRONTEND_URL=https://your-lovable-app.lovable.app

# ---- JWT / AUTH --------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
