  "description": "ORACLE HELIX - AI Sports Intelligence Backend | Powered by BLACKSPIRE HELIX GROUP",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
