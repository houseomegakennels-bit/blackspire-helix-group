        "url": "={{ $env.SUPABASE_URL }}/rest/v1/scheduling_records?order_id=eq.{{ $('Filter 2hr Cooldown').item.json.order_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Profile", "value": "ember_halo" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"post_followup_sent\": true, \"post_followup_at\": \"{{ new Date().toISOString() }}\"}",
        "options": {}
      },
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
