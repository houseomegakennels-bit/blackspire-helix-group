# Approved durable-VPS no-external-provider profile. Inject through an operator
# configuration manager; never commit the real values.
NODE_ENV=production
BLACKSPIRE_RUNTIME_MODE=production
BLACKSPIRE_STATE_OWNER=vps-production
BLACKSPIRE_PROVIDER_MODE=manual
BLACKSPIRE_HERMES_MODE=restricted
TELEGRAM_MODE=dry-run
UNIFIED_IPHONE_TEST_MODE=false
BLACKSPIRE_DB_PATH=/opt/blackspire-command/shared/database/command.sqlite
BLACKSPIRE_DATA_DIR=/opt/blackspire-command/shared/database
PUBLIC_BASE_URL=https://command.example.invalid
# Loopback-only application bind. The reverse proxy is the sole public surface; this port is
# never opened publicly and must never be a wildcard address.
BIND_HOST=127.0.0.1
# Explicit, non-conflicting port. 8787 (existing API/worker) and 8788 (restricted staging) are
# rejected. 8789 is the reviewed preference; confirm it is free with
# `node scripts/select-production-port.js` before activation.
PORT=8789
SECURE_COOKIES=true
RATE_LIMIT_DISABLED=false
DEBUG=false
TRUST_PROXY=true
GIT_WORKFLOW_ENABLED=false
# COMMAND_ADMIN_TOKEN and SESSION_SECRET are required and supplied externally.
